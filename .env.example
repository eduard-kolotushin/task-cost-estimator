# Скопируйте в .env:  copy .env.example .env  (или cp на Unix)
# Полный список читает src/config.py

# --- TaskTracker (обязателен TASKTRACKER_BASE_URL) ---
TASKTRACKER_BASE_URL=https://portal.works.prod.sbt/swtr
# Авторизация: Bearer и/или Basic (user:password); можно оставить оба пустыми при другой схеме доступа
TASKTRACKER_TOKEN=
TASKTRACKER_BASIC_AUTH=
# true — без реальных мутаций к API (создание wiki, PATCH тела, иерархия, связь parent/child — заглушки)
TASKTRACKER_DRY_RUN=false
# false — не проверять TLS (корпоративный прокси/самоподписанный сертификат); true — строгая проверка
TASKTRACKER_VERIFY_SSL=false

# --- Модель ---
# GigaChat-2 | GigaChat-2-Pro | GigaChat-2-Max | или имя модели на OpenAI-совместимом HUB
LLM_MODEL=GigaChat-2

# --- GigaChat (если LLM_MODEL из семейства GigaChat) ---
GIGACHAT_API_KEY=
GIGACHAT_VERIFY_SSL=false

# --- OpenAI-совместимый HUB (если LLM_MODEL не GigaChat) ---
HUB_BASE_URL=http://localhost:12434/v1
HUB_API_KEY=sk-local
HUB_VERIFY_SSL=true

# --- Wiki TaskTracker ---
# Код пространства по умолчанию: инструмент get_wiki_hierarchy подставляет его в filter.spaces,
# если в вызове не передан список spaces
WIKI_SPACE=VIEW

# --- Артефакты single-run (plan.md, created_wiki.json, при --parent-page ещё parent_link.json) ---
TASK_ESTIMATION_RUNS_DIR=runs

# --- Опционально: персистентность LangGraph (чат / memories) ---
POSTGRES_CHECKPOINT_URL=
POSTGRES_STORE_URL=

# Родительская wiki для иерархии не задаётся здесь — только флаг CLI:
#   uv run python -m src.main single-run --wiki-code ... --parent-page VIEW-8278
