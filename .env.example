# Скопируйте в .env и заполните: copy .env.example .env
#
# TaskTracker (обязательно TASKTRACKER_BASE_URL)
TASKTRACKER_BASE_URL=https://portal.works.prod.sbt/swtr
# Один из вариантов авторизации (или оба пустыми, если доступ иначе):
TASKTRACKER_TOKEN=
TASKTRACKER_BASIC_AUTH=
# true — не слать реальные POST/PATCH (создание вернёт фиктивный код)
TASKTRACKER_DRY_RUN=false

# Модель: GigaChat-2 | GigaChat-2-Pro | GigaChat-2-Max | имя модели на HUB
LLM_MODEL=GigaChat-2

# GigaChat (если LLM_MODEL — из семейства GigaChat)
GIGACHAT_API_KEY=
GIGACHAT_VERIFY_SSL=false

# OpenAI-совместимый HUB (если LLM_MODEL — не GigaChat)
HUB_BASE_URL=http://localhost:12434/v1
HUB_API_KEY=sk-local
HUB_VERIFY_SSL=true

# Пространство wiki по умолчанию для подсказок агенту
WIKI_SPACE=VIEW

# Каталог артефактов single-run (plan.md, created_wiki.json)
TASK_ESTIMATION_RUNS_DIR=runs

# Опционально: персистентность LangGraph
POSTGRES_CHECKPOINT_URL=
POSTGRES_STORE_URL=
